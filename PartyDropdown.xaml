<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Sobas_Mob.Views.PartyDropdown"
             Title="Party Selection">

    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="Select Party"
               FontSize="16"
               FontAttributes="Bold" />

        <Picker x:Name="PartyPicker"
                Title="Choose Party"
                ItemDisplayBinding="{Binding PartyName}"
                SelectedIndexChanged="PartyPicker_SelectedIndexChanged" />

    </VerticalStackLayout>
</ContentPage>
